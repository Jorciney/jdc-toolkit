{
  "manifest_version": 3,
  "name": "GitLab AI Code Reviewer",
  "version": "1.0.0",
  "description": "AI-powered code reviews for GitLab merge requests",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  
  "host_permissions": [
    "https://gitlab.com/*",
    "https://*.gitlab.com/*",
    "https://gitlab.cmt.apps.telenet.be/*",
    "https://api.anthropic.com/*"
  ],
  
  "optional_host_permissions": [
    "https://*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://gitlab.com/*/merge_requests/*",
        "https://*.gitlab.com/*/merge_requests/*",
        "https://gitlab.cmt.apps.telenet.be/*/merge_requests/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css", "ai-reviewer.css"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Code Reviewer"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "context/*"],
      "matches": ["<all_urls>"]
    }
  ]
}